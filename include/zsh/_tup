#compdef tup

# Zsh completion script for tup.  Rename this file to _tup and copy
# it into your zsh function path (/usr/share/zsh/site-functions for
# instance)
#
# If you do not want to install it globally, you can copy it somewhere
# else and add that directory to $fpath. This must be done before
# compinit is called. If the file is copied to ~/.zsh.d, your ~/.zshrc
# file could look like this:
#
# fpath=("$HOME/.zsh.d" $fpath)
# autoload -U compinit
# compinit
#

emulate -LR zsh
setopt extendedglob

local curcontext="$curcontext" state line
typeset -A _tup_cmd_globals

_tup() {
  local cmd _tup_root
  integer i=2
  _tup_cmd_globals=()

  while (( i < $#words ))
  do
    case "$words[$i]" in
      -*)
        # skip option
        (( i++ ))
        continue
      ;;
    esac
    if [[ -z "$cmd" ]]
    then
      cmd="$words[$i]"
      words[$i]=()
      (( CURRENT-- ))
    fi
    (( i++ ))
  done

  if [[ -z "$cmd" ]]
  then
    _arguments -s -w : $_tup_global_opts $_tup_opts \
        ':tup command:_tup_commands'
    return
  fi

  # resolve abbreviations and aliases
  if ! (( $+functions[_tup_cmd_${cmd}] ))
  then
    local cmdexp
    (( $#_tup_cmd_list )) || _tup_get_commands

    cmdexp=$_tup_cmd_list[(r)${cmd}*]
    if [[ $cmdexp == $_tup_cmd_list[(R)${cmd}*] ]]
    then
      # might be nice to rewrite the command line with the expansion
      cmd="$cmdexp"
    fi
    if [[ -n $_tup_alias_list[$cmd] ]]
    then
      cmd=$_tup_alias_list[$cmd]
    fi
  fi

  curcontext="${curcontext%:*:*}:tup-${cmd}:"

  zstyle -s ":completion:$curcontext:" cache-policy update_policy

  if [[ -z "$update_policy" ]]
  then
    zstyle ":completion:$curcontext:" cache-policy _tup_cache_policy
  fi
  if (( $+functions[_tup_cmd_${cmd}] ))
  then
    _tup_cmd_${cmd}
  fi
}

_tup_cache_policy() {
  typeset -a old

  # cache for a minute
  old=( "$1"(mm+10) )
  (( $#old )) && return 0

  return 1
}

_tup_get_commands() {
  typeset -ga _tup_cmd_list
  typeset -gA _tup_alias_list

  _tup_cmd_list+="init:Create .tup directory and initialize the tup database"
  _tup_cmd_list+="upd:Updates the set of outputs based on the dependency graph (i.e. \"build\")"
  _tup_cmd_list+="refactor:Check Tupfiles and warn if parsing them caused any changes; no commands are run"
  _tup_cmd_list+="ref:(alias for refactor)"
  _tup_alias_list+=(ref refactor)
  _tup_cmd_list+="monitor:Start the file monitor; eliminates the filesystem scan phase of 'tup upd'"
  _tup_cmd_list+="stop:Stop the file monitor"
  _tup_cmd_list+="variant:create a variant directory with the given config file(s)"
  _tup_cmd_list+="dbconfig:Display current tup dataase config"
  _tup_cmd_list+="options:Display current tup options"
  _tup_cmd_list+="graph:Display a graphviz dependency graph"
  _tup_cmd_list+="todo:Display what 'tup upd' would do without running anything (dry run)"
  _tup_cmd_list+="varsed:(Use inside Tupfile only) Replace @VAR@ references in a file with @-variable values"
  _tup_cmd_list+="scan:Rescan the filesystem for changes; only needed before 'tup graph' if not running the file monitor"
}

_tup_commands() {
  (( $#_tup_cmd_list )) || _tup_get_commands
  _describe -t commands 'tup command' _tup_cmd_list
}

# Common options
_tup_global_opts=(
    '--debug-sql[Show SQL debugging info]'
    '--debug-fuse[Show FUSE debugging info]'
)

# Options for "tup" with no command (identical to the deprecated "tup upd" command)
_tup_opts=(
    '-j[Set number of threads (updater.num_jobs)]:number of jobs/threads:'
    '(--keep-going -k)'{--keep-going,-k}'[Set updater.keep_going option to 1]'
    '--verbose[Display full command strings instead of pretty-printed versions]'
    '--no-keep-going[Set updater.keep_going option to 0]'
    '-d[Output debug log to screen]'
    '--debug-run[Output the :-rules generated by a run-script]'
)

_tup_cmd_init() {
    _arguments -s -w : $_tup_global_opts \
        '--no-sync[Sets the db.sync option of the project to 0]' \
        '*:Directory to initialize:_files -/'
}

_tup_cmd_upd() {
    _arguments -s -w : $_tup_global_opts $_tup_opts \
        "*:Output file:_files"
}

_tup_cmd_refactor() {
    _arguments -s -w : $_tup_global_opts
}

_tup_cmd_monitor() {
    _arguments -s -w : $_tup_global_opts \
        '(--autoupdate -a)'{--autoupdate,-a}'[Automatically rebuild as needed as file changes are detected]' \
        '(--no-autoupdate -n)'{--no-autoupdate,-n}'[Do not automatically rebuild]' \
        '--autoparse[Automatically run parser when file changes are detected]' \
        '--no-autoparse[Do not automatically run parser]' \
        '(--background -b)'{--background,-b}'[Run monitor in the background]' \
        '(--foreground -f)'{--foreground,-f}'[Run monitor in the foreground]' \
        '-d[Enable debugging of the monitor process]' \
        '--verbose[Display full command strings instead of pretty-printed versions]' \
        '--no-keep-going[Set updater.keep_going option to 0]' \
        '--debug-run[Output the :-rules generated by a run-script]'
}

_tup_cmd_stop() {
    _arguments -s -w : $_tup_global_opts
}

_tup_cmd_variant() {
    _arguments -s -w : $_tup_global_opts \
        "*:Variant config file:_files"
}

_tup_cmd_dbconfig() {
    _arguments -s -w : $_tup_global_opts
}

_tup_cmd_options() {
    _arguments -s -w : $_tup_global_opts
}

_tup_cmd_graph() {
    _arguments -s -w : $_tup_global_opts \
        '--dirs[Show directory nodes and Tupfiles]' \
        '--ghosts[Show ghost nodes (files accessed but that don''t exist]' \
        '--environment[Show environment variables]' \
        "*:Output file:_files"
}

_tup_cmd_todo() {
    _arguments -s -w : $_tup_global_opts \
        '--verbose[Display full command strings instead of pretty-printed versions]' \
        "*:Output file:_files"
}

_tup_cmd_varsed() {
    _arguments -s -w : $_tup_global_opts \
        ':Input file:_files' \
        ':Output file:_files'
}

_tup_cmd_scan() {
    _arguments -s -w : $_tup_global_opts
}

_tup "$@"

